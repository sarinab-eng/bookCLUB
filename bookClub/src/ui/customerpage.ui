   <string notr="true">#Sidebar {
    background-color: #2F3E46;
    border-left: 1px solid #354F52;
}
#SidebarTitle {
    color: #CAD2C5;
    font-size: 16px;
    font-weight: bold;
    padding-bottom: 10px;
    border-bottom: 2px solid #52796F;
}
#Sidebar QPushButton {
    background-color: transparent;
    color: #CAD2C5;
    border: none;
    border-radius: 6px;
    padding: 12px 15px;
    font-size: 13px;
    text-align: right;
}
#Sidebar QPushButton:hover {
    background-color: #354F52;
    color: #FFFFFF;
}
#Sidebar QPushButton:checked {
    background-color: #52796F;
    color: #FFFFFF;
    font-weight: bold;
}
#btnLogout {
    background-color: #841C26;
    color: white;
    text-align: center;
}
#btnLogout:hover {
    background-color: #A8201A;
}
#MainStackedWidget {
    background-color: #FAFAFA;
}</string>
