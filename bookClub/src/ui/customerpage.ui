  <property name="windowTitle">
   <string>Customer Panel</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* تم سرخابی هماهنگ - تمامی دکمه‌های منوی سمت چپ (از جمله خروج) با پس‌زمینه سفید */
#CustomerPage {
    background-color: #FFF0F5;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}

#sideMenuFrame {
    background-color: #FF1493;
    border: none;
}

/* --- استایل هدر و لیبل‌ها --- */
#headerFrame {
    background-color: #FFFFFF;
    border-bottom: 2px solid #FFC0CB;
}

/* عنوان BookClub */
#titleLabel {
    color: #C71585;
    font-weight: bold;
    font-size: 18px;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}

/* پیام خوش‌آمدگویی (هم‌اندازه با titleLabel) */
#welcomeLabel {
    color: #FF1493;
    font-weight: bold;
    font-size: 18px;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}


#notificationButton, #logoutTopButton {
    background-color: #FF1493;
    color: #FFFFFF;
    border-radius: 10px;
    padding: 8px 15px;
    font-weight: bold;
}

#notificationButton:hover, #logoutTopButton:hover {
    background-color: #C71585;
}

#contentFrame {
    background-color: #FFF0F5;
    border: none;
}

QLabel#recommendedLabel, QLabel#genreFilterLabel, QLabel#popularLabel,
QLabel#newBooksLabel, QLabel#bestSellerLabel, QLabel#freeBooksLabel {
    color: #FF1493;
    font-weight: bold;
    font-size: 14px;
    padding-top: 6px;
}

QScrollArea {
    border: 2px solid #FFC0CB;
    border-radius: 10px;
    background-color: #FFFFFF;
}

QComboBox {
    border: 2px solid #FFC0CB;
    border-radius: 10px;
    padding: 6px 12px;
    background-color: #FFFFFF;
    color: #333333;
}

QComboBox:hover {
    border-color: #FF1493;
}

QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    border: 2px solid #FFC0CB;
    outline: none;
    selection-background-color: #FF69B4;
    selection-color: #FFFFFF;
}

QComboBox QAbstractItemView::item {
    color: #333333;
    padding: 6px 10px;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #FF69B4;
    color: #FFFFFF;
}

QLineEdit {
    border: 2px solid #FFC0CB;
    border-radius: 10px;
    padding: 6px 12px;
    background-color: #FFFFFF;
    color: #333333;
}

QLineEdit:focus {
    border: 2px solid #FF1493;
}

QTableWidget, QTableView, QListWidget {
    background-color: #FFFFFF;
    border: 2px solid #FFC0CB;
    border-radius: 15px;
    gridline-color: #FFF0F5;
    selection-background-color: #FF69B4;
    selection-color: #FFFFFF;
}

QHeaderView::section {
    background-color: #FF1493;
    color: #FFFFFF;
    padding: 6px;
    border: none;
    font-weight: bold;
}

QTabWidget::pane {
    border: 2px solid #FFC0CB;
    border-radius: 10px;
}

QTabBar::tab {
    background: #FFFFFF;
    color: #FF1493;
    border: 2px solid #FFC0CB;
    border-bottom: none;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    padding: 8px 16px;
    font-weight: bold;
}

QTabBar::tab:selected {
    background: #FF1493;
    color: #FFFFFF;
}

QPushButton {
    background-color: #FF1493;
    color: #FFFFFF;
    border-radius: 10px;
    padding: 8px 15px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #C71585;
}

/* --- تنظیمات عمومی دکمه‌های منوی سمت چپ --- */
QFrame#sideMenuFrame QPushButton {
    background-color: #FFFFFF;
    color: #FF1493;
    border: none;
    border-radius: 10px;
    padding: 12px 15px;
    font-size: 13px;
    font-weight: bold;
    text-align: right;
}

QFrame#sideMenuFrame QPushButton:hover {
    background-color: #FFF0F5;
    color: #C71585;
}

/* --- دکمه خروج پایین سمت چپ با پس‌زمینه سفید --- */
QFrame#sideMenuFrame QPushButton#logoutButton {
    background-color: #FFFFFF;
    color: #E25858;
    margin-top: 10px;
}

QFrame#sideMenuFrame QPushButton#logoutButton:hover {
    background-color: #FFE6E6;
    color: #C0392B;
}
</string>
