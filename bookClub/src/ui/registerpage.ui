<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>RegisterPage</class>
 <widget class="QWidget" name="RegisterPage">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>923</width>
    <height>558</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Form</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QWidget#RegisterPage { 
    background-color: #FFF0F5; /* صورتی بسیار روشن (LavenderBlush) */
}

QLabel#label {
   font-size: 32px;
    font-weight: bold;
    color: #DB7093; /* صورتی تیره */
    margin-bottom: 20px;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}
/* استایل کادر اصلی وسط صفحه */
QFrame#registerFrame {
    background-color: white;
    border-radius: 20px;
    border: 2px solid #FFB6C1;
}

/* استایل فیلدهای ورود متن و کمبوباکس */
QLineEdit, QComboBox {
    border: 2px solid #FFC0CB;
    border-radius: 10px;
    padding: 8px;
    background: #FFFFFF;
    selection-background-color: #FFB6C1;
    font-size: 14px;
}

QLineEdit:focus, QComboBox:focus {
    border: 2px solid #DB7093; /* تغییر رنگ مرز به صورتی هنگام فوکوس */
    background-color: #ffffff;
}

/* استایل کمبوباکس */
QComboBox {
    padding-right: 20px;
}
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left-width: 0px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
}

/* استایل دکمه اصلی ثبت نام */
QPushButton#registerButton {
    background-color: #FF69B4; /* صورتی سرخابی روشن هماهنگ با لاگین */
    color: white;
    border-radius: 10px;
    padding: 10px;
    font-weight: bold;
    font-size: 16px;
    height: 40px;
}

QPushButton#registerButton:hover {
    background-color: #FF1493; /* پررنگ‌تر شدن هنگام قرارگیری ماوس */
}

/* استایل دکمه بازگشت به لاگین (که شبیه به لینک است) */
QPushButton#goToLoginButton {
    background: transparent;
    color: #DB7093;
    text-decoration: underline;
    border: none;
}</string>
  </property>
