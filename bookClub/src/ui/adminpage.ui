  <property name="styleSheet">
   <string notr="true">/* پس‌زمینه اصلی صفحه ادمین */
QWidget#AdminPage { 
    background-color: #FFF0F5; /* صورتی بسیار روشن (LavenderBlush) */
}

/* استایل فیلد جستجو (txtSearch) */
QLineEdit#txtSearch {
    border: 2px solid #FFC0CB;
    border-radius: 10px;
    padding: 8px;
    background: #FFFFFF;
    color: #333333;
    font-size: 13px;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}

QLineEdit#txtSearch:focus {
    border: 2px solid #DB7093; /* صورتی تیره هنگام فوکوس */
}

/* استایل کامبوباکس فیلتر نقش (cmbRoleFilter) */
QComboBox#cmbRoleFilter {
    border: 2px solid #FFC0CB;
    border-radius: 10px;
    padding: 6px 12px;
    background: #FFFFFF;
    min-width: 80px;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}

QComboBox#cmbRoleFilter:hover {
    border-color: #DB7093;
}

QComboBox::drop-down#cmbRoleFilter {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left-width: 0px;
}

/* استایل دکمه ریفرش (refreshButton) */
QPushButton#refreshButton {
    background-color: #FF69B4; /* صورتی سرخابی روشن (همانند دکمه لاگین) */
    color: white;
    border-radius: 10px;
    padding: 8px 15px;
    font-weight: bold;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
    font-size: 13px;
}

QPushButton#refreshButton:hover {
    background-color: #FF1493; /* پررنگ‌تر زمان هاور */
}

/* استایل کادر سمت راست - جزئیات کاربران (detailsGroupBox) */
QGroupBox#detailsGroupBox {
    background-color: #FFFFFF;
    border: 2px solid #FFB6C1;
    border-radius: 20px;
    margin-top: 15px;
    font-weight: bold;
    font-size: 14px;
    color: #DB7093;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}

/* استایل لیبل‌های ثابت پنل سمت راست (نام کاربری:، نقش: و...) */
QLabel {
    color: #DB7093;
    font-weight: bold;
    font-size: 13px;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}

/* استایل لیبل‌های نمایش‌دهنده اطلاعات متغیر (مانند lblDetailUsername و غیره) */
QLabel#titleLable,
QLabel#lblDetailUsername, 
QLabel#lblDetailRole, 
QLabel#lblDetailRegDate, 
QLabel#lblDetailStatus, 
QLabel#lblDetailSpecific {
    border: 2px solid #FFC0CB;
    border-radius: 10px;
    padding: 6px;
    background: #FFFFFF;
    color: #555555;
    font-weight: normal;
    font-size: 13px;
    min-height: 20px;
}

/* استایل فریم دکمه‌ها داخل پنل جزئیات (frame) */
QFrame#frame {
    border: none;
    background: transparent;
}

/* استایل دکمه مسدود/رفع مسدودیت کاربر (btnBlockUser) */
QPushButton#btnBlockUser {
    background-color: #DB7093; /* صورتی تیره هماهنگ با تم */
    color: white;
    border-radius: 10px;
    padding: 10px;
    font-weight: bold;
    font-size: 13px;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}

QPushButton#btnBlockUser:hover {
    background-color: #C71585; /* ارغوانی/صورتی تیره تر هنگام هاور */
}

/* استایل دکمه حذف کاربر (btnDeleteUser) */
QPushButton#btnDeleteUser {
    background-color: #E25858; /* قرمز صورتی ملایم برای دکمه حذف جهت حفظ تم بصری */
    color: white;
    border-radius: 10px;
    padding: 10px;
    font-weight: bold;
    font-size: 13px;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}

QPushButton#btnDeleteUser:hover {
    background-color: #C0392B; /* قرمز تیره تر */
}

/* استایل جدول اصلی نمایش کاربران */
QTableView, QTableWidget {
    background-color: #FFFFFF;
    border: 2px solid #FFC0CB;
    border-radius: 15px;
    gridline-color: #FFF0F5;
    selection-background-color: #FFB6C1;
    selection-color: #FFFFFF;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}

QHeaderView::section {
    background-color: #FFB6C1;
    color: white;
    padding: 6px;
    border: 1px solid #FFF0F5;
    font-weight: bold;
}</string>
