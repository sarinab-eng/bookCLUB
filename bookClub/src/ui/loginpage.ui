  <property name="styleSheet">
   <string notr="true">/* پس‌زمینه اصلی صفحه */
QWidget#LoginPage { 
    background-color: #FFF0F5; /* صورتی بسیار روشن (LavenderBlush) */
}

/* استایل کادر وسطی (پنل لاگین) */
QFrame#mainFrame {
    background-color: white;
    border-radius: 20px;
    border: 2px solid #FFB6C1; /* صورتی ملایم */
}

/* استایل کادر اسم برنامه */
QLabel#lblTitle {
    font-size: 32px;
    font-weight: bold;
    color: #DB7093; /* صورتی تیره */
    margin-bottom: 20px;
    font-family: &quot;Segoe UI&quot;, &quot;Tahoma&quot;;
}

/* استایل ورودی‌های متن (Username/Password) */
QLineEdit {
    border: 2px solid #FFC0CB;
    border-radius: 10px;
    padding: 8px;
    background: #FFFFFF;
    selection-background-color: #FFB6C1;
    font-size: 14px;
}

QLineEdit:focus {
    border: 2px solid #DB7093; /* وقتی کاربر کلیک می‌کند پررنگ‌تر شود */
}

/* استایل دکمه ورود */
QPushButton#loginButton {
    background-color: #FF69B4; /* صورتی سرخابی روشن */
    color: white;
    border-radius: 10px;
    padding: 10px;
    font-weight: bold;
    font-size: 16px;
}

QPushButton#loginButton:hover {
    background-color: #FF1493; /* وقتی موس روی دکمه می‌رود پررنگ‌تر شود */
}

/* استایل دکمه ثبت‌نام (که لینک‌مانند باشد) */
QPushButton#goToRegisterButton {
    background: transparent;
    color: #DB7093;
    text-decoration: underline;
    border: none;
}</string>
